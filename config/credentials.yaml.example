# QuantClaw Credentials Configuration
# Copy this file to ~/.quantclaw/credentials.yaml and fill in your keys

# ============ 用户管理 ============
# 用户列表由插件自动管理，也可以手动添加
users:
  - userId: "admin"
    tier: "vip"
    apiKey: "qc_your_admin_api_key_here"
    createdAt: "2024-01-01T00:00:00Z"
  - userId: "demo"
    tier: "free"
    apiKey: "qc_demo_key_for_testing"
    createdAt: "2024-01-01T00:00:00Z"

# ============ 交易所 API ============
exchanges:
  binance:
    api_key: ""
    secret: ""
    # testnet: true  # 使用测试网

  okx:
    api_key: ""
    secret: ""
    passphrase: ""

  bybit:
    api_key: ""
    secret: ""

  gate:
    api_key: ""
    secret: ""

# ============ 行情数据源 ============
market_data:
  coingecko:
    api_key: ""  # 免费版可空，Pro 版填写

  coinmarketcap:
    api_key: ""

# ============ 链上数据源 ============
onchain:
  arkham:
    api_key: ""

  nansen:
    api_key: ""

  dune:
    api_key: ""

  etherscan:
    api_key: ""

  bscscan:
    api_key: ""

# ============ 宏观数据源 ============
macro:
  fred:
    api_key: ""  # Federal Reserve Economic Data

  tradingeconomics:
    api_key: ""
