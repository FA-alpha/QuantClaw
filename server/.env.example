# QuantClaw Webhook Server - 环境变量配置示例
# 复制此文件为 .env 并填写实际值

# 服务端口
PORT=8080

# 用户数据文件路径
QUANTCLAW_DATA_PATH=~/.quantclaw/users.json

# Workspace 根目录（workspace 会创建为 ~/clawd-{agent_id}）
QUANTCLAW_WORKSPACE_BASE=~

# 模板路径（新用户 workspace 模板）
QUANTCLAW_TEMPLATE_PATH=~/work/QuantClaw/templates/agent-workspace

# Skills 路径（软链接到用户 workspace）
QUANTCLAW_SKILLS_PATH=~/work/QuantClaw/skills

# 默认 AI 模型
QUANTCLAW_DEFAULT_MODEL=openrouter/anthropic/claude-sonnet-4-5

# 是否允许自动注册新用户（true/false）
QUANTCLAW_AUTO_REGISTER=true

# API 基础地址（所有 skill 脚本的请求地址，默认 http://52.53.212.195:7002/Mobile）
# QUANTCLAW_API_BASE=http://52.53.212.195:7002/Mobile

# Token 验证 API 地址
QUANTCLAW_TOKEN_API=http://52.53.212.195:7002/Mobile/Account/usage_info

# Token 验证超时时间（毫秒）
QUANTCLAW_TOKEN_TIMEOUT=5000

# ============ app_docker.py 专用配置 ============

# 聊天记录存储目录（容器内独立路径，与宿主机分离）
# 默认: /home/node/quantclaw/server/data-docker
# 说明: Docker 版本使用此独立目录，不与宿主机 data/ 混用
QUANTCLAW_DATA_DIR=/home/node/quantclaw/server/data-docker
